[user]
	name = Zack Breakstone
	email = z.breakstone@gmail.com
[colors]
	ui = true
[core]
	autocrlf = input
[push]
	default = simple
[pull]
	rebase = true
[rerere]
	enabled = true
[color]
	ui = true
[alias]
	s = status -s
	lg = log --oneline --decorate --all --graph
	co = checkout
	br = branch
	cm = commit
[credential]
	helper = osxkeychain
